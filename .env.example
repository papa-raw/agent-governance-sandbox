# Anthropic API key for LLM agent delegates
# Get yours at https://console.anthropic.com/
# If not set, the simulation uses deterministic agent behavior
VITE_ANTHROPIC_API_KEY=

# Storacha delegation proof for decentralized state storage
# Base64-encoded UCAN delegation proof
# If not set, CIDs are computed locally using SHA-256
VITE_STORACHA_PROOF=
