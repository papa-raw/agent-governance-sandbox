    classDef agent fill:#243042,stroke:#2D3F52,color:#E8ECF1,stroke-width:2px
    classDef commons fill:#1A2332,stroke:#1ABC9C,color:#E8ECF1,stroke-width:2px
    classDef warn fill:#F1C40F22,stroke:#F1C40F,color:#F1C40F,stroke-width:1px
