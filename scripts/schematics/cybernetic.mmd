graph TB
    subgraph ENTRY["Dual-Gated Entry"]
        STAKE["🏦 Stake Gate<br/>Min 30 Resources"]:::stake
        REP["⭐ Reputation Gate<br/>≥40 to Propose"]:::rep
    end

    subgraph DELIBERATION["Multistage Deliberation"]
        D1["1 — Straw Poll"]:::delib
        D2["2 — Deliberation"]:::delib
        D3["3 — Binding Vote"]:::delib
        D1 --> D2 --> D3
    end

    subgraph QUADRATIC["Quadratic Voting"]
        QV["√stake = votes<br/>Threshold-Disclosure Ballots"]:::quad
    end

    subgraph ORACLE["Ecological Oracle"]
        ECO["📊 Ecosystem Metrics<br/>Health • Biodiversity • Stock"]:::oracle
        ENFORCE["⚡ Algorithmic Enforcement"]:::enforce
        ECO -->|"trigger"| ENFORCE
    end

    subgraph SANCTIONS["Graduated Response"]
        W["⚠ Warning"]:::warn
        P["💸 Penalty + Slash 15%"]:::penalize
        SU["⏸ Suspension"]:::suspend
        EX["🚫 Exclusion"]:::exclude
        W --> P --> SU --> EX
    end

    A1["🌿 Stakeholders"]:::agent
    COMMONS["Camargue Commons"]:::commons

    A1 -->|"stake + register"| STAKE
    A1 -->|"earn standing"| REP
    REP -->|"propose"| D1
    D3 -->|"ratify"| QV
    QV -->|"enact rules"| COMMONS
    COMMONS -->|"state signals"| ECO
    ENFORCE -->|"graduated"| SANCTIONS
    SANCTIONS -.->|"feedback"| A1
    A1 <-->|"extract · contribute"| COMMONS

